{
  "name": "infra-ops",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "user",
  "workspaceFolder": "/workspace/infra",
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace/infra,type=bind"
  ],
  "runArgs": ["--dns=100.100.100.100", "--dns=1.1.1.1"],
  "postCreateCommand": "bash .devcontainer/postCreateCommand.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "hashicorp.terraform",
        "redhat.vscode-yaml"
      ]
    }
  }
}
